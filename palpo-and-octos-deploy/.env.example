# ============================================================
# Robrix + Palpo + Octos — Environment Variables
# ============================================================
# Copy this file to .env and fill in the required values.
#
#   cp .env.example .env
#
# Only DEEPSEEK_API_KEY is required. Everything else has
# sensible defaults for local development.
# ============================================================

# [REQUIRED] Your LLM API key
# Get one at https://platform.deepseek.com/
DEEPSEEK_API_KEY=your-api-key-here

# [Optional] PostgreSQL password for Palpo's database
DB_PASSWORD=palpo_dev_password

# [Optional] Log level for Octos
RUST_LOG=octos=debug,info
